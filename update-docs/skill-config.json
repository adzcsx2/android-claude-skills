{
  "name": "update-docs",
  "description": "Android 项目文档自动生成工具。分析项目结构，生成中文技术文档，支持增量更新。使用 /update-docs 触发。",
  "tools": ["Read", "Glob", "Grep", "Bash", "Write", "Edit"],
  "userInvocable": true,
  "commands": {
    "/update-docs": "增量更新所有文档",
    "/update-docs --force": "强制重新生成所有文档",
    "/update-docs --dry-run": "仅分析不生成文件，预览将要更新的内容",
    "/update-docs interfaces": "仅生成界面文档",
    "/update-docs navigation": "仅生成导航文档",
    "/update-docs components": "仅生成四大组件文档",
    "/update-docs notifications": "仅生成通知文档",
    "/update-docs api": "仅生成 API 文档"
  },
  "outputLocation": "项目根目录的 docs/ 文件夹",
  "documents": [
    {
      "filename": "PROJECT_OVERVIEW.md",
      "description": "项目概览（基本信息、架构、技术栈）",
      "sourceFiles": ["build.gradle", "settings.gradle", "AndroidManifest.xml"]
    },
    {
      "filename": "INTERFACES.md",
      "description": "界面文档（控件分析、功能说明）",
      "sourceFiles": ["app/src/main/res/layout/*.xml", "**/*Activity.java", "**/*Activity.kt", "**/*Fragment.java", "**/*Fragment.kt"]
    },
    {
      "filename": "NAVIGATION.md",
      "description": "导航文档（Activity-Fragment 关系、跳转关系）",
      "sourceFiles": ["**/*Activity.java", "**/*Activity.kt", "**/*Fragment.java", "**/*Fragment.kt"]
    },
    {
      "filename": "COMPONENTS.md",
      "description": "四大组件文档",
      "sourceFiles": ["AndroidManifest.xml", "**/*Service.java", "**/*Receiver.java", "**/*Provider.java"]
    },
    {
      "filename": "NOTIFICATIONS.md",
      "description": "通知文档（渠道配置、通知类型）",
      "sourceFiles": ["**/*.java", "**/*.kt"]
    },
    {
      "filename": "BUILD_VARIANTS.md",
      "description": "构建变体文档",
      "sourceFiles": ["app/build.gradle", "app/build.gradle.kts"]
    },
    {
      "filename": "DEPENDENCIES.md",
      "description": "依赖库文档",
      "sourceFiles": ["app/build.gradle", "app/build.gradle.kts", "build.gradle", "build.gradle.kts"]
    },
    {
      "filename": "API.md",
      "description": "API 接口文档（URL 和方法）",
      "sourceFiles": ["**/*Api.java", "**/*Service.java", "**/*Api.kt", "**/*Service.kt"]
    },
    {
      "filename": "CHANGELOG.md",
      "description": "文档更新日志",
      "sourceFiles": []
    }
  ],
  "metadataFile": "docs/.doc-metadata.json",
  "metadataStructure": {
    "version": "1.0",
    "projectType": "android",
    "lastUpdate": "ISO8601日期时间",
    "documents": {
      "DOCUMENT_NAME.md": {
        "updatedAt": "ISO8601日期时间",
        "sourceFiles": ["关联的源文件列表"]
      }
    }
  },
  "analysisPatterns": {
    "activityNavigation": [
      "startActivity\\(new Intent\\(.*?,\\s*(\\w+Activity)\\.class\\)\\)",
      "ActivityUtil\\.next\\(.*?,\\s*(\\w+Activity)\\.class\\)",
      "(\\w+Activity)\\.start\\(",
      "(\\w+Activity)\\.launch\\("
    ],
    "fragmentSwitch": [
      "beginTransaction\\(\\)[\\s\\S]*?replace\\((\\w+),\\s*(\\w+Fragment)",
      "viewPager\\.setCurrentItem\\((\\d+)\\)",
      "viewPager2\\.setCurrentItem\\((\\d+)\\)"
    ],
    "controlDetection": [
      "findViewById\\(R\\.id\\.(\\w+)\\)",
      "binding\\.(\\w+)",
      "android:onClick=\"(\\w+)\""
    ],
    "notificationChannel": [
      "NotificationChannel\\([\"']([^\"']+)[\"'],\\s*[\"']([^\"']+)[\"']",
      "createNotificationChannel\\("
    ],
    "apiEndpoint": [
      "@GET\\([\"']([^\"']+)[\"']\\)",
      "@POST\\([\"']([^\"']+)[\"']\\)",
      "@PUT\\([\"']([^\"']+)[\"']\\)",
      "@DELETE\\([\"']([^\"']+)[\"']\\)",
      "[\"'](https?://[^\"']+)[\"']",
      "[\"'](\\/api\\/[^\"']+)[\"']"
    ]
  },
  "controlTypeMapping": {
    "TextView": {"type": "TextView", "category": "显示类"},
    "EditText": {"type": "EditText", "category": "输入类"},
    "Button": {"type": "Button", "category": "交互类"},
    "ImageButton": {"type": "ImageButton", "category": "交互类"},
    "ImageView": {"type": "ImageView", "category": "显示类"},
    "RecyclerView": {"type": "RecyclerView", "category": "容器类"},
    "ListView": {"type": "ListView", "category": "容器类"},
    "ViewPager": {"type": "ViewPager", "category": "容器类"},
    "ViewPager2": {"type": "ViewPager2", "category": "容器类"},
    "WebView": {"type": "WebView", "category": "显示类"},
    "ProgressBar": {"type": "ProgressBar", "category": "显示类"},
    "CheckBox": {"type": "CheckBox", "category": "输入类"},
    "RadioButton": {"type": "RadioButton", "category": "输入类"},
    "Switch": {"type": "Switch", "category": "输入类"},
    "SeekBar": {"type": "SeekBar", "category": "输入类"}
  },
  "functionInference": {
    "LoginActivity": "用户登录界面",
    "RegisterActivity": "用户注册界面",
    "MainActivity": "应用主界面",
    "SettingActivity": "设置界面",
    "ProfileActivity": "个人资料界面",
    "MessageActivity": "消息详情界面",
    "ChatActivity": "聊天界面",
    "CallActivity": "通话界面",
    "SearchActivity": "搜索界面"
  },
  "notes": [
    "所有文档使用中文编写",
    "时间格式使用 ISO 8601 标准",
    "相对路径使用 / 分隔符",
    "元数据文件 .doc-metadata.json 不应提交到版本控制",
    "每次更新都会在 CHANGELOG.md 中记录"
  ]
}
